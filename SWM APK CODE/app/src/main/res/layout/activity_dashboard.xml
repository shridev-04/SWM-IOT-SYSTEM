<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- Subtle Futuristic Lottie Background -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.2" />

    <!-- Network / MQTT Status Banner -->
    <TextView
        android:id="@+id/tvStatusBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accent_red"
        android:padding="8dp"
        android:text="NO INTERNET"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:visibility="gone"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ESP32 Hardware Health Status Top Bar (Static Placeholder) -->
    <LinearLayout
        android:id="@+id/layoutTopHealth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatusBanner">
        
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/accent_green"
            android:layout_marginStart="8dp" />
        
        <TextView
            android:id="@+id/tvSignal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIGNAL: --%"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="4dp"
            android:fontFamily="sans-serif-medium"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
            
        <TextView
            android:id="@+id/tvPing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PING: --ms"
            android:textSize="10sp"
            android:textColor="@color/accent_cyan"
            android:fontFamily="sans-serif-medium"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
            
        <TextView
            android:id="@+id/tvUptime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPTIME: --h --m"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#00000000"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintTop_toBottomOf="@id/layoutTopHealth" />

    <!-- Bottom Actions Container (Glassmorphic) -->
    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_glass"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnUpdateData"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="UPDATE SWM LIMITS"
            android:background="@drawable/bg_cyberpunk_glass_button"
            android:textColor="@color/accent_cyan"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnUpdate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="REFRESH DATA"
            android:background="@drawable/bg_cyberpunk_glass_button"
            android:textColor="@color/accent_cyan"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />
    </LinearLayout>

    <!-- Reaction Emoji -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieEmoji"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:elevation="6dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Welcome Header -->
            <TextView
                android:id="@+id/tvHelloUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hello, User!"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SWM SYSTEM STATUS OVERVIEW"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="24dp" />

            <!-- Region Selection / ZIP Code Input -->
            <LinearLayout
                android:id="@+id/layoutRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_cyberpunk_glass"
                android:layout_marginBottom="24dp">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="@color/accent_cyan" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="ZIP CODE"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />
                    
                <EditText
                    android:id="@+id/etZipCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:padding="8dp"
                    android:hint="6-Digit PIN"
                    android:textColorHint="@color/text_tertiary"
                    android:textColor="@color/accent_cyan"
                    android:inputType="number"
                    android:maxLength="6"
                    android:background="@drawable/bg_cyberpunk_input"
                    android:textAlignment="center"
                    android:textSize="14sp" />
                    
                <Button
                    android:id="@+id/btnSaveZip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:text="SAVE"
                    android:textColor="@color/bg_deep"
                    android:backgroundTint="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <!-- New: Calculated Target & Mode UI Boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:baselineAligned="false">

                <!-- Calculated Target -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cyberpunk_glass"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALC TARGET"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />
                        
                    <TextView
                        android:id="@+id/tvTargetTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textColor="@color/accent_amber"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Operating Mode -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cyberpunk_glass"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RELAYS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />
                        
                    <TextView
                        android:id="@+id/tvRelayStat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IDLE"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 3D Temperature Ring Display -->
            <LinearLayout
                android:id="@+id/layoutTempRing"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_border_glow"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:elevation="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WATER TEMP"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvWaterTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0°C"
                    android:textColor="@color/text_primary"
                    android:textSize="48sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <!-- New: Relay Countdown UI Box -->
            <LinearLayout
                android:id="@+id/layoutCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_cyberpunk_glass"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:visibility="gone">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="@color/accent_red" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="RELAY LOCK:"
                    android:textColor="@color/accent_red"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />
                    
                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="59s"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Mini Gauges Row (Static Placeholders) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp"
                android:baselineAligned="false">

                <!-- Outside Temp -->
                <LinearLayout
                    android:id="@+id/layoutOutsideTemp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cyberpunk_glass"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OUTSIDE TEMP"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />
                        
                    <TextView
                        android:id="@+id/tvOutsideTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textColor="@color/accent_green"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                        
                    <TextView
                        android:id="@+id/tvOutsideUnitLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C Feels Like"
                        android:textColor="@color/accent_green"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Unit Toggle -->
                <LinearLayout
                    android:id="@+id/btnUnitToggle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cyberpunk_glass_button"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TEMP UNIT"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />
                        
                    <TextView
                        android:id="@+id/tvCurrentUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textColor="@color/accent_cyan"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Click to Change"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SWM ACTUAL STATUS"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- GRID LAYOUT FOR ACTUAL ESP32 LIMITS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp"
                android:baselineAligned="false">

                <!-- Actual Hot -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_smoke_hot"
                            android:padding="16dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SWM HOT"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvEspHotLimit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--°C"
                                android:textColor="@color/accent_red"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-light" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Actual Cold -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_smoke_cold"
                            android:padding="16dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SWM COLD"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvEspColdLimit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--°C"
                                android:textColor="@color/accent_cyan"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-light" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SWM TEMPERATURE SETUP"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Set Hot Boundary -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_smoke_hot"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SET HOT BOUNDARY"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />
                            
                        <TextView
                            android:id="@+id/tvHotLimit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40°C"
                            android:textColor="@color/accent_red"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    
                    <SeekBar
                        android:id="@+id/sbHot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="30"
                        android:progress="10"
                        android:minHeight="4dp"
                        android:maxHeight="4dp"
                        android:thumbTint="@color/accent_red"
                        android:progressDrawable="@android:drawable/progress_horizontal"
                        android:progressTint="@color/accent_red" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Set Cold Boundary -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_smoke_cold"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SET COLD BOUNDARY"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />
                            
                        <TextView
                            android:id="@+id/tvColdLimit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15°C"
                            android:textColor="@color/accent_cyan"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    
                    <SeekBar
                        android:id="@+id/sbCold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="20"
                        android:progress="10"
                        android:minHeight="4dp"
                        android:maxHeight="4dp"
                        android:thumbTint="@color/accent_cyan"
                        android:progressDrawable="@android:drawable/progress_horizontal"
                        android:progressTint="@color/accent_cyan" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Force Temperature Mode -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardForce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/layoutForceContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_smoke_force"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="FORCE OVERRIDE"
                            android:textColor="@color/accent_amber"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchForce"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/accent_amber"
                            app:trackTintMode="src_in" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvForceTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="0.0°C"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutForceSeekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5°C"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp" />

                        <SeekBar
                            android:id="@+id/sbForce"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="55"
                            android:progress="20"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:minHeight="12dp"
                            android:maxHeight="12dp"
                            android:progressTint="@color/accent_amber"
                            android:thumbTint="@color/accent_amber" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="60°C"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvForceInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Override active. Boundaries bypassed."
                        android:textColor="@color/accent_amber"
                        android:textSize="10sp"
                        android:textAlignment="center"
                        android:layout_marginTop="12dp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>



            <!-- Emergency Shutdown -->
            <Button
                android:id="@+id/btnEmergency"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="EMERGENCY SHUTDOWN"
                android:background="@drawable/bg_cyberpunk_glass_red_button"
                android:textColor="@color/accent_red"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />
                
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
