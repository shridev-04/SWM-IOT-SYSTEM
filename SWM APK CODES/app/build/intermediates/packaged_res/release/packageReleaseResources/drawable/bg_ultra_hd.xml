<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#030712" /> <!-- Extremely Dark Deep Navy Base -->
        </shape>
    </item>
    <!-- Overlay subtle dark gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="800dp"
                android:centerX="0.5"
                android:centerY="0.2"
                android:startColor="#0D1A30"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
