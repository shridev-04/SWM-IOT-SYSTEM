<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@drawable/bg_splash_gradient">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ System Configuration"
        android:textColor="@color/accent_cyan"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="35dp"
        android:gravity="center"
        android:fontFamily="sans-serif-condensed" />

    <EditText
        android:id="@+id/etHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="MQTT Host Address"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/edit_text_premium"
        android:layout_marginBottom="15dp"
        android:singleLine="true" />

    <EditText
        android:id="@+id/etUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="MQTT Username"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/edit_text_premium"
        android:layout_marginBottom="15dp"
        android:singleLine="true" />

    <EditText
        android:id="@+id/etPass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="MQTT Password"
        android:inputType="textPassword"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/edit_text_premium"
        android:layout_marginBottom="35dp"
        android:singleLine="true" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="CONNECT &amp; SAVE"
        android:background="@drawable/btn_premium"
        android:textColor="@color/bg_deep"
        android:textStyle="bold"
        android:textSize="16sp"
        android:fontFamily="sans-serif-condensed"
        android:letterSpacing="0.05" />

</LinearLayout>
